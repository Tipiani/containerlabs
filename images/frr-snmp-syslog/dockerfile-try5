FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# ?? Instalar dependencias base + herramientas �tiles
RUN apt update && apt install -y \
    librtr0 librtr-dev rtr-tools \
    python3-dev gcc python3-cffi \
    cmake build-essential libssh-dev libtool autoconf \
    git autoconf automake libtool make libreadline-dev texinfo \
    pkg-config libpam0g-dev libjson-c-dev bison flex \
    libc-ares-dev python3-sphinx \
    install-info build-essential libsnmp-dev perl \
    libcap-dev libelf-dev libunwind-dev \
    protobuf-c-compiler libprotobuf-c-dev \
    autoconf \
    git \
    build-essential \
    libreadline-dev \
    pkg-config \
    libssl-dev \
    libjson-c-dev \
    bison \
    flex \
    libsystemd-dev \
    libpcre2-dev \
    cmake \
    curl \
    ca-certificates \
    rsyslog \
    snmp \
    snmpd \
    iproute2 \
    iputils-ping \
    net-tools \
    tcpdump \
    nano

RUN git clone https://github.com/CESNET/libyang.git /libyang
WORKDIR /libyang
RUN git checkout v2.1.128
RUN mkdir build
WORKDIR build
RUN cmake --install-prefix /usr \
      -D CMAKE_BUILD_TYPE:String="Release" ..
RUN make
RUN make install
WORKDIR ..
WORKDIR ..

# ?? Clonar FRR (elige versi�n estable si quieres)
# por ejm: https://github.com/FRRouting/frr/tree/stable/8.3
# RUN git clone https://github.com/FRRouting/frr.git /frr
# RUN git clone https://github.com/FRRouting/frr/tree/stable/9.0/frr.git /frr
RUN git clone -b stable/9.0 --single-branch https://github.com/FRRouting/frr.git /frr

WORKDIR /frr

# ?? Compilar FRR con TODO lo que necesitas
RUN ./bootstrap.sh
RUN ./configure \
    --prefix=/usr \
    --localstatedir=/var/run/frr \
    --sbindir=/usr/lib/frr \
    --sysconfdir=/etc/frr \
    --enable-pimd \
    --enable-watchfrr \
    --enable-rpki \
    --enable-snmp \
    --enable-multipath=64 \
    --enable-user=frr \
    --enable-group=frr \
    --enable-vtysh \
    --disable-isisd \
    --disable-ripd \
    --disable-ripngd
RUN make
RUN  make install
#    && make -j$(nproc) \
#    && make install

# ?? Crear usuario FRR
RUN groupadd -r frr && useradd -r -g frr frr

# ?? Crear directorios necesarios
RUN mkdir -p /etc/frr /var/log/frr && \
    chown -R frr:frr /etc/frr /var/log/frr

# ?? Config b�sica FRR
RUN echo -e "zebra=yes\nbgpd=yes\n" > /etc/frr/daemons

# ?? Config SNMP b�sica
RUN echo "rocommunity public" > /etc/snmp/snmpd.conf && \
    echo "agentAddress udp:161" >> /etc/snmp/snmpd.conf

# ?? Config syslog remoto (EDITA ESTA IP)
RUN echo "*.* @10.23.3.250" >> /etc/rsyslog.conf

# ?? Script de arranque
COPY start.sh /start.sh
RUN chmod +x /start.sh

CMD ["/start.sh"]
